<idea-plugin>
  <id>dev.doria.intellij</id>
  <name>Doria Language Support</name>
  <vendor>Doria</vendor>

  <description><![CDATA[
    Adds Doria language support for IntelliJ-based IDEs, including .doria file recognition,
    syntax highlighting, editor configuration, and doria-lsp integration.
  ]]></description>

  <depends>com.intellij.modules.platform</depends>
  <depends optional="true" config-file="doria-lsp.xml">com.intellij.modules.lsp</depends>

  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceImplementation="dev.doria.intellij.settings.DoriaSettings" />

    <fileType
      name="Doria"
      language="doria"
      implementationClass="dev.doria.intellij.DoriaFileType"
      fieldName="INSTANCE"
      extensions="doria" />

    <lang.syntaxHighlighterFactory
      language="doria"
      implementationClass="dev.doria.intellij.highlighting.DoriaSyntaxHighlighterFactory" />

    <colorSettingsPage implementation="dev.doria.intellij.highlighting.DoriaColorSettingsPage" />

    <lang.parserDefinition
      language="doria"
      implementationClass="dev.doria.intellij.psi.DoriaParserDefinition" />

    <lang.commenter
      language="doria"
      implementationClass="dev.doria.intellij.DoriaCommenter" />

    <annotator
      language="doria"
      implementationClass="dev.doria.intellij.highlighting.DoriaVariableUsageAnnotator" />

    <applicationConfigurable
      parentId="language"
      instance="dev.doria.intellij.settings.DoriaConfigurable"
      id="dev.doria.intellij.settings"
      displayName="Doria" />

  </extensions>

  <actions>
    <action
      id="dev.doria.intellij.actions.DoriaCreateFileAction"
      class="dev.doria.intellij.actions.DoriaCreateFileAction"
      text="Doria File"
      description="Create a Doria file with a main function"
      icon="/icons/doria.svg">
      <add-to-group group-id="NewGroup" anchor="before" relative-to-action="NewFile" />
    </action>
    <action
      id="dev.doria.intellij.actions.DoriaCreateClassAction"
      class="dev.doria.intellij.actions.DoriaCreateClassAction"
      text="Doria Class"
      description="Create a Doria class"
      icon="/icons/doria.svg">
      <add-to-group
        group-id="NewGroup"
        anchor="after"
        relative-to-action="dev.doria.intellij.actions.DoriaCreateFileAction" />
    </action>
  </actions>
</idea-plugin>
