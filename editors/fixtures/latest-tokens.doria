// Planned/future: enums and expression-position match.
enum Option
{
    case Some(int $value);
    case None;
}

let $score = match ($option) {
    Some($value) => $value,
    None => 0,
};

// Planned/future: checked errors.
function loadUser(int $id): User throws UserNotFound, DatabaseError
{
    if ($id < 1) {
        throw new UserNotFound($id);
    }

    return new User();
}

try {
    loadUser(42);
} catch (UserNotFound $e) {
    echo "missing";
} finally {
    echo "done";
}

// Planned/future: closure capture uses with, not PHP closure use.
let $adder = function (int $x): int with ($base) {
    return $x + $base;
};

let $mover = function (): void with (take $resource) {
    echo "taken";
};

