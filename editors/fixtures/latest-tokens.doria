    }
}

trait TracksChanges
{
    int64 $lastChangedAt;
    int[] $changedLines;
}

class Post
{
    uses HasSlug, TracksChanges;
}

function publish(take Post $post): void
{
    return;
}

function main(): void
{
    let $name = "Doria";
    let writable $count = 0;
    ?User $maybeUser = null;

    int8 $tiny = 1;
    int16 $small = 2;
    int32 $medium = 3;
    int64 $large = 9223372036854775807;
    uint8 $byte = 1;
    uint16 $port = 3306;
    uint32 $flags = 0;
    uint64 $id = 18446744073709551615;
    float $defaultFloat = 1.5;
    float32 $ratio = 1.5;
    float64 $distance = 10.5;
    bool $enabled = true;
    mixed $metadata = null;
    never $impossible = fail();

    // Naming charter: built-in free functions are snake_case; member APIs are camelCase.
    let $now = get_time();
    let $startsWithDor = str_starts_with($name, "Dor");
    let $wrapped = Int::wrappingAdd(1, 2);
    let $empty = $name->isEmpty();
    Message $message = new Message();
    let $report = new App\Report();
    PersonRepository $repository = new PersonRepository();
    $message->retryAfter(seconds: 30);
    echo $message->tenantId;
    $repository->findById($id);

    echo "Hello " . $name . "!";
    echo "Hello {$name}";
    echo "Hello {$this->name}";
    echo "Profile: {$this->profile->displayName}";
    echo "Count: {$count}";
    echo 'Literal {$name}';
    echo "\n\t\r\s";

    if ($count == 0 and not false) {
        echo "ok";
    } else if ($count != 1 or true) {
        echo "also ok";
    } else {
        echo "done";
    }

    if (($flags & 1) == 1 || (($flags | 2) ^ 3) != 0) {
        echo "bitwise";
    }

    while ($count < 3) {
        $count++;
        continue;
    }

    for (let writable $i = 0; $i < 10; $i++) {
        echo "x";
    }

    foreach (0..<10 as $i) {
        echo "r";
    }

    foreach (0..10 as $i) {
        break;
    }

    return;
}

// Stage 13: fixed-width integers, explicit conversions, and integer operators.
function exerciseStage13Integers(): void
{
    int8 $minimumInt8 = -128;
    int16 $maximumInt16 = 32767;
    int32 $maximumInt32 = 2147483647;
    int64 $maximumInt64 = 9223372036854775807;
    uint8 $maximumUInt8 = 255;
    uint16 $maximumUInt16 = 65535;
    uint32 $maximumUInt32 = 4294967295;
    uint64 $maximumUInt64 = 18446744073709551615;

    int $defaultInt = Int::from($maximumInt16);
    int8 $convertedInt8 = Int8::from($minimumInt8);
    int16 $convertedInt16 = Int16::from($minimumInt8);
    int32 $convertedInt32 = Int32::from($maximumInt16);
    int64 $convertedInt64 = Int64::from($maximumInt32);
    uint8 $convertedUInt8 = UInt8::from($maximumUInt8);
    uint16 $convertedUInt16 = UInt16::from($maximumUInt8);
    uint32 $convertedUInt32 = UInt32::from($maximumUInt16);
    uint64 $convertedUInt64 = UInt64::from($maximumUInt32);

    let $negated = -$defaultInt;
    let $complemented = ~$defaultInt;
    let $sum = $defaultInt + 2;
    let $difference = $defaultInt - 2;
    let $product = $defaultInt * 2;
    let $quotient = $defaultInt / 2;
    let $remainder = $defaultInt % 2;
    let $shiftedLeft = $defaultInt << 1;
    let $shiftedRight = $defaultInt >> 1;
    let $masked = $defaultInt & 255;
    let $combined = $defaultInt | 1;
    let $toggled = $defaultInt ^ 1;
    let $equal = $defaultInt == 42;
    let $notEqual = $defaultInt != 0;
    let $less = $defaultInt < 100;
    let $lessOrEqual = $defaultInt <= 42;
    let $greater = $defaultInt > 0;
    let $greaterOrEqual = $defaultInt >= 42;
    let $booleanXor = true xor false;

    writable int16 $accumulator = 12;
    $accumulator += 3;
    $accumulator -= 2;
    $accumulator *= 2;
    $accumulator /= 2;
    $accumulator %= 5;
    $accumulator <<= 1;
    $accumulator >>= 1;
    $accumulator &= 7;
    $accumulator |= 8;
    $accumulator ^= 3;
    $accumulator++;
    $accumulator--;
}

// Stage 14: IEEE floats, runtime bool values, and default cross-kind conversions.
function exerciseStage14Scalars(int $whole, bool $input): int
{
    writable float32 $delta = 0.016;
    $delta += 1.0;
    $delta--;

    float $ratio = 1.0 / 3.0;
    float64 $wideAlias = Int::toFloat($whole);
    bool $ready = true;
    let $both = $ready and not false;
    bool $either = $input or $both;
    bool $different = $either xor false;
    bool $symbolNegated = !$input;
    bool $symbolBoth = $ready && $symbolNegated;
    bool $symbolEither = $symbolBoth || $different;

    if ($symbolEither and $ratio > 0.0 and $wideAlias >= 0.0) {
        return Float::toInt($wideAlias);
    }

    return 0;
}

