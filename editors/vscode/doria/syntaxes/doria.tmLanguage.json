{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Doria",
  "scopeName": "source.doria",
  "patterns": [
    {
      "include": "#attributes"
    },
    {
      "include": "#invalid"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#accessors"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#calls"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.doria",
          "begin": "(#\\[)\\s*([A-Za-z_][A-Za-z0-9_]*)",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.attribute.begin.doria"
            },
            "2": {
              "name": "entity.name.function.attribute.doria"
            }
          },
          "end": "\\]",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.attribute.end.doria"
            }
          },
          "patterns": [
            {
              "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(:)",
              "captures": {
                "1": {
                  "name": "variable.parameter.named.doria"
                },
                "2": {
                  "name": "punctuation.separator.key-value.doria"
                }
              }
            },
            {
              "include": "#strings"
            },
            {
              "include": "#types"
            },
            {
              "include": "#accessors"
            },
            {
              "include": "#variables"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#keywords"
            },
            {
              "include": "#invalid"
            },
            {
              "include": "#operators"
            },
            {
              "include": "#punctuation"
            }
          ]
        }
      ]
    },
    "invalid": {
      "patterns": [
        {
          "name": "invalid.illegal.preprocessor.doria",
          "match": "^\\s*#(?:include|define|undef|if|ifdef|ifndef|elif|else|endif|warning|error)\\b.*$"
        },
        {
          "name": "invalid.illegal.operator.strict-comparison.doria",
          "match": "===|!=="
        },
        {
          "name": "invalid.illegal.keyword.goto.doria",
          "match": "\\bgoto\\b"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.doria",
          "begin": "/\\*\\*",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.begin.doria"
            }
          },
          "end": "\\*/",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.end.doria"
            }
          },
          "patterns": [
            {
              "match": "(@method)\\s+(?:(static)\\s+)?((?:\\??[A-Za-z_\\\\][A-Za-z0-9_\\\\]*(?:<[^>]+>)?(?:\\[\\])?)(?:\\|\\??[A-Za-z_\\\\][A-Za-z0-9_\\\\]*(?:<[^>]+>)?(?:\\[\\])?)*)\\s+([A-Za-z_][A-Za-z0-9_]*)",
              "captures": {
                "1": {
                  "name": "keyword.other.documentation.tag.doria"
                },
                "2": {
                  "name": "storage.modifier.static.doria"
                },
                "3": {
                  "name": "storage.type.documentation.doria"
                },
                "4": {
                  "name": "entity.name.function.method.documentation.doria"
                }
              }
            },
            {
              "match": "(@param)\\s+((?:\\??[A-Za-z_\\\\][A-Za-z0-9_\\\\]*(?:<[^>]+>)?(?:\\[\\])?)(?:\\|\\??[A-Za-z_\\\\][A-Za-z0-9_\\\\]*(?:<[^>]+>)?(?:\\[\\])?)*)\\s+(\\$[A-Za-z_][A-Za-z0-9_]*)",
              "captures": {
                "1": {
                  "name": "keyword.other.documentation.tag.doria"
                },
                "2": {
                  "name": "storage.type.documentation.doria"
                },
                "3": {
                  "name": "variable.other.doria"
                }
              }
            },
            {
              "match": "(@property(?:-read|-write)?)\\s+((?:\\??[A-Za-z_\\\\][A-Za-z0-9_\\\\]*(?:<[^>]+>)?(?:\\[\\])?)(?:\\|\\??[A-Za-z_\\\\][A-Za-z0-9_\\\\]*(?:<[^>]+>)?(?:\\[\\])?)*)\\s+(\\$[A-Za-z_][A-Za-z0-9_]*)",
              "captures": {
                "1": {
                  "name": "keyword.other.documentation.tag.doria"
                },
                "2": {
                  "name": "storage.type.documentation.doria"
                },
                "3": {
                  "name": "variable.other.doria"
                }
              }
            },
            {
              "match": "(@(?:return|throws|var|template|extends|implements))\\s+((?:\\??[A-Za-z_\\\\][A-Za-z0-9_\\\\]*(?:<[^>]+>)?(?:\\[\\])?)(?:\\|\\??[A-Za-z_\\\\][A-Za-z0-9_\\\\]*(?:<[^>]+>)?(?:\\[\\])?)*)",
              "captures": {
                "1": {
                  "name": "keyword.other.documentation.tag.doria"
                },
                "2": {
                  "name": "storage.type.documentation.doria"
                }
              }
            },
            {
              "name": "keyword.other.documentation.tag.doria",
              "match": "@[A-Za-z_][A-Za-z0-9_-]*"
            },
            {
              "include": "#variables"
            }
          ]
        },
        {
          "name": "comment.line.double-slash.doria",
          "match": "//.*$"
        },
        {
          "name": "comment.line.number-sign.doria",
          "match": "#(?!\\[).*$"
        },
        {
          "name": "comment.block.doria",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.doria",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.doria",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.doria",
              "begin": "(\\{)(?=\\$)",
              "beginCaptures": {
                "1": {
                  "name": "string.quoted.double.doria"
                }
              },
              "end": "\\}",
              "endCaptures": {
                "0": {
                  "name": "string.quoted.double.doria"
                }
              },
              "patterns": [
                {
                  "include": "#accessors"
                },
                {
                  "include": "#variables"
                }
              ]
            },
            {
              "name": "variable.language.this.doria",
              "match": "\\$this\\b"
            },
            {
              "name": "variable.other.doria",
              "match": "\\$[A-Za-z_][A-Za-z0-9_]*"
            }
          ]
        },
        {
          "name": "string.quoted.single.doria",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.doria",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(namespace)\\s+([A-Za-z_][A-Za-z0-9_]*(?:\\\\[A-Za-z_][A-Za-z0-9_]*)*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.namespace.doria"
            },
            "2": {
              "name": "entity.name.namespace.doria"
            }
          }
        },
        {
          "name": "meta.trait-composition.doria",
          "begin": "^\\s+(use)\\b(?=\\s+[A-Z][A-Za-z0-9_]*(?:\\s*(?:,|;)))",
          "beginCaptures": {
            "1": {
              "name": "keyword.other.trait-use.doria"
            }
          },
          "end": "(;)",
          "endCaptures": {
            "1": {
              "name": "punctuation.terminator.statement.doria"
            }
          },
          "patterns": [
            {
              "name": "entity.name.type.trait.doria",
              "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
            },
            {
              "name": "punctuation.separator.comma.doria",
              "match": ","
            }
          ]
        },
        {
          "name": "meta.import.doria",
          "begin": "^(use)\\b(?=\\s+[A-Za-z_][A-Za-z0-9_]*(?:\\\\[A-Za-z_][A-Za-z0-9_]*)+)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.import.doria"
            }
          },
          "end": "(;)",
          "endCaptures": {
            "1": {
              "name": "punctuation.terminator.statement.doria"
            }
          },
          "patterns": [
            {
              "match": "(\\bas\\b)\\s+([A-Za-z_][A-Za-z0-9_]*)",
              "captures": {
                "1": {
                  "name": "keyword.operator.alias.doria"
                },
                "2": {
                  "name": "entity.name.type.alias.doria"
                }
              }
            },
            {
              "name": "punctuation.separator.namespace.doria",
              "match": "\\\\"
            },
            {
              "name": "entity.name.namespace.doria",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            }
          ]
        },
        {
          "match": "\\b(class)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.class.doria"
            },
            "2": {
              "name": "entity.name.type.class.doria"
            }
          }
        },
        {
          "match": "\\b(interface)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.interface.doria"
            },
            "2": {
              "name": "entity.name.type.interface.doria"
            }
          }
        },
        {
          "match": "\\b(trait)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.trait.doria"
            },
            "2": {
              "name": "entity.name.type.trait.doria"
            }
          }
        },
        {
          "match": "\\b(function)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.function.doria"
            },
            "2": {
              "name": "entity.name.function.doria"
            }
          }
        },
        {
          "match": "\\b(new)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.operator.new.doria"
            },
            "2": {
              "name": "entity.name.type.doria"
            }
          }
        },
        {
          "name": "keyword.directive.doria",
          "match": "\\b(?:include|declare)\\b"
        }
      ]
    },
    "accessors": {
      "patterns": [
        {
          "match": "(->)\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "keyword.operator.accessor.doria"
            },
            "2": {
              "name": "entity.name.function.method.call.doria"
            }
          }
        },
        {
          "match": "(->)\\s*([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.operator.accessor.doria"
            },
            "2": {
              "name": "variable.other.property.doria"
            }
          }
        },
        {
          "match": "(::)\\s*([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "punctuation.accessor.static.doria"
            },
            "2": {
              "name": "entity.name.function.static.doria"
            }
          }
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.language.this.doria",
          "match": "\\$this\\b"
        },
        {
          "name": "variable.other.doria",
          "match": "\\$[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.doria",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.doria",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "constant.language.boolean.doria",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "name": "constant.language.null.doria",
          "match": "\\bnull\\b"
        },
        {
          "name": "keyword.control.doria",
          "match": "\\b(?:return|foreach|as|if|else|while|for|break|continue|when|given|finally|extends|implements)\\b"
        },
        {
          "name": "storage.modifier.mutability.doria",
          "match": "\\b(?:writable|readonly)\\b"
        },
        {
          "name": "storage.modifier.visibility.doria",
          "match": "\\b(?:internal)\\b"
        },
        {
          "name": "keyword.declaration.variable.doria",
          "match": "\\b(?:let)\\b"
        },
        {
          "name": "keyword.other.echo.doria",
          "match": "\\b(?:echo)\\b"
        },
        {
          "name": "storage.modifier.static.doria",
          "match": "\\b(?:static)\\b"
        },
        {
          "name": "keyword.other.reserved.doria",
          "match": "\\b(?:async|await|spawn|scope|enum|match|try|catch|throw)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "begin": "\\b(List|Dictionary|Set)\\s*(<)",
          "beginCaptures": {
            "1": {
              "name": "support.type.collection.doria"
            },
            "2": {
              "name": "punctuation.definition.generic.begin.doria"
            }
          },
          "end": ">",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.generic.end.doria"
            }
          },
          "patterns": [
            {
              "name": "punctuation.separator.generic.doria",
              "match": ","
            },
            {
              "include": "#types"
            }
          ]
        },
        {
          "name": "storage.type.primitive.doria",
          "match": "\\b(?:void|int|int8|int16|int32|int64|uint8|uint16|uint32|uint64|float|float32|float64|string|bool|mixed|object|resource|array)\\b"
        },
        {
          "name": "support.type.collection.doria",
          "match": "\\b(?:List|Dictionary|Set)\\b"
        },
        {
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\b\\s*(?=\\$)",
          "captures": {
            "1": {
              "name": "entity.name.type.doria"
            }
          }
        },
        {
          "match": "(:)\\s*([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "punctuation.separator.type.doria"
            },
            "2": {
              "name": "entity.name.type.doria"
            }
          }
        },
        {
          "name": "entity.name.type.doria",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "calls": {
      "patterns": [
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.call.doria"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.word.doria",
          "match": "\\b(?:not|and|or|xor)\\b"
        },
        {
          "name": "keyword.operator.doria",
          "match": "==|!=|<=|>=|&&|\\|\\||\\?\\?|=>|->|::|\\+=|-=|[=+\\-*/%.<>!?:]"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.doria",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.doria",
          "match": ","
        },
        {
          "name": "punctuation.section.doria",
          "match": "[\\[\\]{}()]"
        }
      ]
    }
  }
}
