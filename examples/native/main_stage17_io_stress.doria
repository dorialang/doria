function main(): void
{
    let writable $contents = read_file("seed.txt");
    let writable $line = readline();
    let writable $count = 0;

    while ($line != null) {
        $contents = $contents . sprintf("|%s:%d", $line, $count);
        write_file("output.txt", $contents);
        $line = readline();
        $count++;
    }

    echo read_file("output.txt");
}
