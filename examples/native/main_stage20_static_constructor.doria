class Message
{
    static writable int $age = 0;

    function __construct(string $text)
    {
        Message::age = 37;
    }

    function __destruct()
    {
        echo "message released\n";
    }
}

function main(): void
{
    let $message = new Message("hello");
    echo Message::age;
    echo "\n";
}
